{
    "name": "laraditz/courier-jt-express",
    "description": "J&T Express Malaysia driver for laraditz/courier.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Raditz Farhan",
            "email": "ahmad.farhan@globaltium.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laraditz/courier": "@dev",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "autoload": {
        "psr-4": {
            "Laraditz\\Courier\\JtExpress\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laraditz\\Courier\\JtExpress\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../courier"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Laraditz\\Courier\\JtExpress\\JtExpressServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
